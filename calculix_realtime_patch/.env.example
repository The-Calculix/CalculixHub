# Frontend-safe values. These may be used by Vite/React in the browser.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Backend-only values. Never expose SUPABASE_SERVICE_ROLE_KEY to frontend code.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# GitHub Actions / CI secrets are configured in GitHub, not committed here.
SUPABASE_ACCESS_TOKEN=""
SUPABASE_DB_URL=""
VERCEL_TOKEN=""
